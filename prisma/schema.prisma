// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sale     Sales[]
}

model Products {
  id            Int      @id @default(autoincrement())
  name          String
  units         Int
  price         Decimal @db.Decimal(10,2)
  salesDetails  salesDetail[]
  urlImg        String
}

model Sales{
  id              Int @id @default(autoincrement())
  date            DateTime
  totalPrice      Decimal @db.Decimal(10,2)
  salesman        User @relation (fields: [salesmanId], references: [id])
  salesmanId      Int
  salesDetails    salesDetail[]
}
model salesDetail{
  rowId        Int @id @default(autoincrement())
  sale         Sales @relation(fields: [saleId], references: [id])
  saleId       Int
  product      Products @relation (fields: [productId], references: [id])
  productId    Int
  salesPrice   Decimal @db.Decimal(10,2)
  quantity     Int
  rowTotal     Decimal @db.Decimal(10,2)
}

